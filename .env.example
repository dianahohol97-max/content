# bloom focus — Environment Variables
# Copy this to .env and fill in your values
# Never commit .env to GitHub

# ── Claude API (text generation) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI API (DALL-E image generation) ──────────────────
OPENAI_API_KEY=sk-...

# ── Google Sheets (review queue) ──────────────────────────
# Get from the URL: docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Service account key — either a file path or the full JSON string
# Option A (file path):
GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json
# Option B (JSON string — better for Make.com / CI):
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ── ElevenLabs (optional voiceover) ───────────────────────
# Only needed if you enable voiceover in video-generator.js
# ELEVENLABS_API_KEY=your_key_here
# ELEVENLABS_VOICE_ID=your_voice_id_here
